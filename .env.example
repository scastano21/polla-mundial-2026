# Copia a .env.local y rellena con tus valores. No subas claves reales a Git.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago: Access Token desde "Tus integraciones" (puedes usar credenciales de prueba).
# NEXT_PUBLIC_APP_URL debe ser la URL pública de la app (https en producción).
# Usada por Mercado Pago, enlaces de redirect, sitemap, metadatos OG y JSON-LD — en Vercel pon la URL del dominio definitivo.
# Webhooks: Mercado Pago llama a notification_url; en local suele fallar sin HTTPS (usa ngrok o prueba en deploy).
MP_ACCESS_TOKEN=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional (si usas OAuth u otros flujos MP):
# MP_PUBLIC_KEY=
# MP_CLIENT_ID=
# MP_CLIENT_SECRET=

# Recuperar contraseña: en Supabase → Authentication → URL configuration añade Redirect URLs:
#   http://localhost:3000/update-password
#   https://TU_DOMINIO/update-password

# Panel /admin: marca is_admin en public.profiles, o en la raíz:
#   npm run set-admin -- tu-correo@gmail.com
# (requiere SUPABASE_SERVICE_ROLE_KEY en .env.local)

ADMIN_SECRET_KEY=
CRON_SECRET=
