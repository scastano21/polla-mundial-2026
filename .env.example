# ─────────────────────────────────────────────────────────────
# Copia este archivo a .env.local y rellena los valores.
# Nunca subas .env.local a Git ni pegues claves reales en .env.example.
# En Vercel: misma lista en Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API — mismo proyecto para las tres)
NEXT_PUBLIC_SUPABASE_URL=
# Clave «anon» / «public» (JWT eyJ...). NO uses la service_role aquí.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave «service_role» — solo servidor / scripts; no la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago (Tus integraciones → credenciales de prueba o producción)
MP_ACCESS_TOKEN=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional MP (OAuth u otras integraciones si las usas)
MP_PUBLIC_KEY=
MP_CLIENT_ID=
MP_CLIENT_SECRET=

# Protección extra para rutas o cron si las implementas (deja vacío si no aplica)
ADMIN_SECRET_KEY=
CRON_SECRET=

# Recuperar contraseña: Supabase → Authentication → URL configuration → Redirect URLs:
#   http://localhost:3000/update-password
#   https://TU_DOMINIO/update-password

# Panel /admin del torneo: usuario con is_admin en public.profiles
#   npm run set-admin -- tu-correo@gmail.com
# (requiere SUPABASE_SERVICE_ROLE_KEY en .env.local)

# Webhooks MP: notification_url apunta a tu dominio público; en local suele fallar sin HTTPS (ngrok o probar en deploy).
