# Copia este archivo como .env.local y reemplaza con valores reales.
# No subas .env.local a Git. Aquí solo van nombres de variables y ejemplos sin secretos.
# En Vercel: Settings → Environment Variables con los mismos nombres.

# Supabase (Dashboard → Project Settings → API — mismo proyecto)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Football API (cron / datos en vivo — si lo usas)
FOOTBALL_DATA_API_KEY=

# Vercel Cron / webhooks internos (string largo aleatorio en producción)
CRON_SECRET=

# App URL pública (OBLIGATORIO en Vercel: https://tu-app.vercel.app — NO dejes localhost en producción)
# Usada por MercadoPago, sitemap y enlaces de correo cuando no hay navegador.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase → Authentication → URL configuration (producción):
#   Site URL = https://tu-app.vercel.app
#   Redirect URLs: https://tu-app.vercel.app/** , http://localhost:3000/**
# Sin esto los correos de confirmación pueden apuntar a localhost.
# Para menos spam: Authentication → SMTP (correo propio) o plantillas con tu dominio.

# MercadoPago (Checkout Pro / donaciones)
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_CLIENT_ID=
MP_CLIENT_SECRET=

# Precio Premium COP (debe coincidir con la preferencia y validación del webhook, si aplica)
PREMIUM_PRICE_COP=9900

# Opcional: protección extra en rutas admin o scripts (déjalo vacío si no lo usas)
ADMIN_SECRET_KEY=

# Recuperar contraseña: Supabase → Authentication → URL configuration → Redirect URLs:
#   http://localhost:3000/update-password
#   https://TU_DOMINIO/update-password

# Panel /admin: npm run set-admin -- tu-correo@gmail.com
# Respaldo en Vercel (si RLS falla): lista de emails admin del torneo, separados por coma
TOURNAMENT_ADMIN_EMAILS=sebascossio1990@gmail.com
